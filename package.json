{
  "name": "img-crop",
  "version": "1.0.0",
  "description": "Vue 3 image cropping components — interactive cropper and antdv-next Upload integration",
  "keywords": [
    "antdv-next",
    "crop",
    "cropper",
    "image-crop",
    "upload",
    "vue",
    "vue3"
  ],
  "license": "MIT",
  "author": "Bin",
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "check": "vp check",
    "dev": "turbo run dev",
    "format": "vp fmt .",
    "lint": "vp lint .",
    "lint:fix": "vp lint . --fix",
    "prepare": "simple-git-hooks",
    "test": "turbo run test",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "catalog:types",
    "simple-git-hooks": "catalog:tooling",
    "tsx": "catalog:tooling",
    "turbo": "catalog:tooling",
    "typescript": "catalog:tooling",
    "vite-plus": "catalog:tooling",
    "vue-tsc": "catalog:vue"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged"
  },
  "lint-staged": {
    "*.{js,ts,tsx,vue,json}": [
      "vp lint --fix",
      "vp fmt"
    ]
  },
  "packageManager": "pnpm@10.34.1"
}
