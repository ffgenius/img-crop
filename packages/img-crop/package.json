{
  "name": "@antdv-next/img-crop",
  "version": "1.0.0",
  "description": "Image cropper integrated with antdv-next Upload. Wrap an Upload component, crop in a modal, get the cropped file in beforeUpload.",
  "keywords": [
    "ant-design-vue",
    "antdv-next",
    "crop",
    "cropper",
    "image",
    "upload",
    "vue"
  ],
  "license": "MIT",
  "files": [
    "dist"
  ],
  "type": "module",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack -w"
  },
  "dependencies": {
    "@antdv-next/vue-easy-crop": "workspace:*"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "catalog:vue",
    "unplugin-vue": "catalog:vue",
    "vue": "catalog:vue",
    "vue-tsc": "catalog:vue"
  },
  "peerDependencies": {
    "antdv-next": "*",
    "vue": ">=3.0.0"
  }
}
