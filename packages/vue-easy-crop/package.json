{
  "name": "@antdv-next/vue-easy-crop",
  "version": "1.0.0",
  "description": "A Vue 3 component to crop images and videos with easy interactions. Drag, zoom, rotate, keyboard & touch support.",
  "keywords": [
    "crop",
    "cropper",
    "image crop",
    "vue",
    "vue3"
  ],
  "license": "MIT",
  "type": "module",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack -w",
    "test": "vp test",
    "test:all": "vp test && playwright test",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:watch": "vp test --watch"
  },
  "dependencies": {
    "normalize-wheel": "catalog:tooling"
  },
  "devDependencies": {
    "@playwright/test": "catalog:testing",
    "@vitejs/plugin-vue": "catalog:vue",
    "playwright": "catalog:testing",
    "unplugin-vue": "catalog:vue",
    "vue": "catalog:vue",
    "vue-tsc": "catalog:vue"
  },
  "peerDependencies": {
    "vue": ">=3.0.0"
  }
}
